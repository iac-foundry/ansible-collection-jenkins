#!/usr/bin/env bash
set -euo pipefail

log() {
  echo "[$(date -Iseconds)] $*"
}

require_var() {
  local name="$1"
  if [[ -z "${!name:-}" ]]; then
    log "Missing required environment variable: ${name}"
    exit 1
  fi
}

require_var JENKINS_URL
require_var JENKINS_USER
require_var JENKINS_API_TOKEN
require_var JENKINS_NODE_NAME
require_var CONTAINER_NAME
require_var MIN_ONLINE_AFTER_RESTART
require_var RECONNECT_WAIT_SECONDS

CURL_AUTH=( -u "${JENKINS_USER}:${JENKINS_API_TOKEN}" )

jenkins_get() {
  local path="$1"
  curl -fsS "${CURL_AUTH[@]}" "${JENKINS_URL}${path}"
}

jenkins_post() {
  local path="$1"
  local crumb_field=""
  local crumb_value=""
  local crumb_json=""

  if crumb_json="$(curl -fsS "${CURL_AUTH[@]}" "${JENKINS_URL}/crumbIssuer/api/json" 2>/dev/null)"; then
    crumb_field="$(echo "${crumb_json}" | jq -r '.crumbRequestField // empty')"
    crumb_value="$(echo "${crumb_json}" | jq -r '.crumb // empty')"
  fi

  if [[ -n "${crumb_field}" && -n "${crumb_value}" ]]; then
    curl -fsS -X POST "${CURL_AUTH[@]}" -H "${crumb_field}: ${crumb_value}" "${JENKINS_URL}${path}" >/dev/null
  else
    curl -fsS -X POST "${CURL_AUTH[@]}" "${JENKINS_URL}${path}" >/dev/null
  fi
}

COMPUTERS_JSON="$(jenkins_get '/computer/api/json?tree=computer[displayName,offline,temporarilyOffline,idle]')"
NODE_JSON="$(echo "${COMPUTERS_JSON}" | jq -c --arg node "${JENKINS_NODE_NAME}" '.computer[] | select(.displayName == $node)')"

if [[ -z "${NODE_JSON}" ]]; then
  log "Node ${JENKINS_NODE_NAME} not found in Jenkins; refusing recycle"
  exit 1
fi

NODE_OFFLINE="$(echo "${NODE_JSON}" | jq -r '.offline')"
NODE_IDLE="$(echo "${NODE_JSON}" | jq -r '.idle')"
ONLINE_COUNT="$(echo "${COMPUTERS_JSON}" | jq '[.computer[] | select(.displayName != "Built-In Node") | select(.offline == false)] | length')"

if [[ "${NODE_IDLE}" != "true" ]]; then
  log "Node ${JENKINS_NODE_NAME} is busy; skipping recycle"
  exit 0
fi

if (( ONLINE_COUNT - 1 < MIN_ONLINE_AFTER_RESTART )); then
  log "Insufficient capacity for safe recycle (online=${ONLINE_COUNT}, minimum_after_restart=${MIN_ONLINE_AFTER_RESTART}); skipping"
  exit 0
fi

if [[ "${NODE_OFFLINE}" != "true" ]]; then
  log "Temporarily taking node ${JENKINS_NODE_NAME} offline before container restart"
  jenkins_post "/computer/${JENKINS_NODE_NAME}/toggleOffline?offlineMessage=Scheduled%20worker%20recycle"
  sleep 3
fi

COMPUTERS_JSON="$(jenkins_get '/computer/api/json?tree=computer[displayName,offline,temporarilyOffline,idle]')"
NODE_JSON="$(echo "${COMPUTERS_JSON}" | jq -c --arg node "${JENKINS_NODE_NAME}" '.computer[] | select(.displayName == $node)')"
NODE_IDLE="$(echo "${NODE_JSON}" | jq -r '.idle')"

if [[ "${NODE_IDLE}" != "true" ]]; then
  log "Node ${JENKINS_NODE_NAME} became busy while preparing recycle; restoring online state"
  NODE_TEMP_OFFLINE="$(echo "${NODE_JSON}" | jq -r '.temporarilyOffline')"
  if [[ "${NODE_TEMP_OFFLINE}" == "true" ]]; then
    jenkins_post "/computer/${JENKINS_NODE_NAME}/toggleOffline"
  fi
  exit 0
fi

log "Restarting container ${CONTAINER_NAME}"
docker restart "${CONTAINER_NAME}" >/dev/null
sleep "${RECONNECT_WAIT_SECONDS}"

COMPUTERS_JSON="$(jenkins_get '/computer/api/json?tree=computer[displayName,offline,temporarilyOffline,idle]')"
NODE_JSON="$(echo "${COMPUTERS_JSON}" | jq -c --arg node "${JENKINS_NODE_NAME}" '.computer[] | select(.displayName == $node)')"
NODE_TEMP_OFFLINE="$(echo "${NODE_JSON}" | jq -r '.temporarilyOffline')"

if [[ "${NODE_TEMP_OFFLINE}" == "true" ]]; then
  log "Bringing node ${JENKINS_NODE_NAME} back online"
  jenkins_post "/computer/${JENKINS_NODE_NAME}/toggleOffline"
fi

log "Worker recycle completed for ${JENKINS_NODE_NAME}"

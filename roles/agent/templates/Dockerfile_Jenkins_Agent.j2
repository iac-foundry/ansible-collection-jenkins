FROM {{ jenkins_agent_base_image }}

USER root

# Install CI tooling needed by deployment jobs running on inbound worker nodes:
# - ansible-galaxy / ansible-playbook (ansible-core)
# - terraform and packer (HashiCorp repo)
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      gnupg \
      python3 \
      python3-pip \
      xorriso \
      unzip; \
    mkdir -p /etc/apt/keyrings; \
    curl -fsSL https://apt.releases.hashicorp.com/gpg | gpg --dearmor -o /etc/apt/keyrings/hashicorp.gpg; \
    . /etc/os-release; \
    echo "deb [signed-by=/etc/apt/keyrings/hashicorp.gpg] https://apt.releases.hashicorp.com ${VERSION_CODENAME} main" > /etc/apt/sources.list.d/hashicorp.list; \
    apt-get update; \
{% if jenkins_agent_install_hashicorp_tools | bool and jenkins_agent_install_terraform | bool and jenkins_agent_install_packer | bool %}
    apt-get install -y --no-install-recommends terraform packer vault; \
{% elif jenkins_agent_install_hashicorp_tools | bool and jenkins_agent_install_terraform | bool %}
    apt-get install -y --no-install-recommends terraform vault; \
{% elif jenkins_agent_install_hashicorp_tools | bool and jenkins_agent_install_packer | bool %}
    apt-get install -y --no-install-recommends packer vault; \
{% else %}
    apt-get install -y --no-install-recommends vault; \
{% endif %}
    python3 -m pip install --no-cache-dir --break-system-packages ansible-core=={{ jenkins_agent_ansible_core_version }}; \
    rm -rf /var/lib/apt/lists/*

USER jenkins

jenkins:
  systemMessage: "Managed by Ansible + JCasC + JobDSL. UI edits may be overwritten."
  numExecutors: 0
  mode: NORMAL
  remotingSecurity:
    enabled: true

{% if jenkins_oidc_enabled | default(false) | bool %}
  securityRealm:
    oic:
      clientId: "${jenkins-oidc-client-id}"
      clientSecret: "${jenkins-oidc-client-secret}"
      serverConfiguration:
        wellKnown:
          wellKnownOpenIDConfigurationUrl: "{{ jenkins_oidc_well_known_url }}"
          scopesOverride: "{{ jenkins_oidc_scopes }}"
      userNameField: "{{ jenkins_oidc_username_field }}"
      fullNameFieldName: "{{ jenkins_oidc_full_name_field }}"
      emailFieldName: "{{ jenkins_oidc_email_field }}"
      groupsFieldName: "{{ jenkins_oidc_groups_field }}"
      disableSslVerification: false
      logoutFromOpenidProvider: true
      sendScopesInTokenRequest: true
{% if jenkins_escape_hatch_enabled | default(false) | bool %}
      properties:
        - escapeHatch:
            username: "{{ jenkins_escape_hatch_username }}"
            secret: "${jenkins-escape-hatch-password}"
            group: "app-jenkins-admin"
{% endif %}

  authorizationStrategy:
    roleBased:
      roles:
        global:
          - name: "admin"
            permissions:
              - "Overall/Administer"
            entries:
              - group: "app-jenkins-admin"
          - name: "global-read"
            permissions:
              - "Overall/Read"
            entries:
              - either: "authenticated"
        items:
{% set folder_defaults = {} %}
{% for folder_def in (jenkins_job_folder_roles | default([])) %}
{% set _ = folder_defaults.update({folder_def.folder: folder_def.roles}) %}
{% endfor %}
{% for job in (jenkins_jobs | default([])) %}
{% set job_name = job.job_name | default('main') %}
{% set effective_roles = job.roles if (job.roles is defined) else folder_defaults.get(job.folder, []) %}
{% for role_def in effective_roles %}
{% set perm_list = [] %}
{% if 'read' in role_def.permissions %}{% set _ = perm_list.append('Job/Read') %}{% endif %}
{% if 'build' in role_def.permissions %}{% set _ = perm_list.extend(['Job/Build', 'Job/Cancel', 'Job/Workspace']) %}{% endif %}
{% set role_slug = (job.folder ~ '/' ~ job_name ~ '/' ~ role_def.group) | lower | replace(' ', '-') | replace('/', '--') %}
          - name: "{{ role_slug }}"
            pattern: "^{{ job.folder }}/{{ job_name }}(/.*)?$"
            permissions:
{% for perm in perm_list %}
              - "{{ perm }}"
{% endfor %}
            entries:
              - group: "{{ role_def.group }}"
{% endfor %}
{% endfor %}
{% endif %}

unclassified:
  location:
    url: "{{ jenkins_root_url }}"

  mailer:
    smtpHost: "{{ jenkins_smtp_host }}"
    smtpPort: "{{ jenkins_smtp_port }}"
    useSsl: {{ jenkins_smtp_use_tls | bool | lower }}
{% if jenkins_smtp_use_auth | default(false) | bool %}
    authentication:
      username: "{{ jenkins_smtp_username }}"
      password: "{{ jenkins_smtp_password }}"
{% endif %}
    replyToAddress: "{{ jenkins_admin_email }}"
    charset: "UTF-8"

{% if (jenkins_global_shared_libraries | default([]) | length) > 0 %}
  globalLibraries:
    libraries:
{% for lib in (jenkins_global_shared_libraries | sort(attribute='name')) %}
    - name: "{{ lib.name }}"
      defaultVersion: "{{ lib.default_version | default('main') }}"
      implicit: {{ (lib.implicit | default(false)) | bool | lower }}
      allowVersionOverride: {{ (lib.allow_version_override | default(true)) | bool | lower }}
      includeInChangesets: {{ (lib.include_in_changesets | default(true)) | bool | lower }}
      retriever:
        modernSCM:
          scm:
            git:
              remote: "{{ lib.repo_url }}"
{% if (lib.credentials_id | default('') | string | length) > 0 %}
              credentialsId: "{{ lib.credentials_id }}"
{% endif %}
{% endfor %}
{% endif %}

jobs:
  - script: |-
{% set seen_folders = [] %}
{# Sort jobs deterministically by folder then job_name to ensure stable JCasC output #}
{% for job in (jenkins_jobs | sort(attribute='job_name') | sort(attribute='folder')) %}
{% set job_type = job.job_type | default('pipeline') %}
{% set job_name = job.job_name | default('main') %}
{% set parts = job.folder.split('/') %}
{% for i in range(1, parts | length + 1) %}
{% set ancestor = parts[:i] | join('/') %}
{% if ancestor not in seen_folders %}
{% set _ = seen_folders.append(ancestor) %}
      folder('{{ ancestor }}') {
        description('Managed as code. Do not edit manually.')
      }
{% endif %}
{% endfor %}
{% if job_type == 'multibranch' %}
{% set multibranch_discover = job.discover_branches | default(jenkins_jobdsl_multibranch_discover_branches | default(true)) %}
      multibranchPipelineJob('{{ job.folder }}/{{ job_name }}') {
        description('{{ job.description | default("Managed as code.") }}')
        branchSources {
          branchSource {
            source {
              git {
                id('{{ (job.folder ~ '/' ~ job_name) | replace(' ', '-') | replace('/', '-') | lower }}')
                remote('{{ job.repo_url }}')
{% if jenkins_jobdsl_use_jenkins_credentials | bool %}
                credentialsId('{{ jenkins_jobdsl_git_credentials_id }}')
{% endif %}
{% if multibranch_discover | bool %}
                traits {
                  gitBranchDiscovery()
                }
{% endif %}
              }
            }
          }
        }
        factory {
          workflowBranchProjectFactory {
            scriptPath('{{ job.script_path | default("Jenkinsfile") }}')
          }
        }
        orphanedItemStrategy {
          discardOldItems {
            numToKeep({{ job.num_to_keep | default(20) }})
          }
        }
      }

{% else %}
      pipelineJob('{{ job.folder }}/{{ job_name }}') {
        description('{{ job.description | default("Managed as code.") }}')
        definition {
          cpsScm {
            scm {
              git {
                remote {
                  url('{{ job.repo_url }}')
{% if jenkins_jobdsl_use_jenkins_credentials | bool %}
                  credentials('{{ jenkins_jobdsl_git_credentials_id }}')
{% endif %}
                }
                branch('*/{{ job.branch | default("main") }}')
              }
            }
            scriptPath('{{ job.script_path | default("Jenkinsfile") }}')
            lightweight(true)
          }
        }
      }

{% endif %}

{% endfor %}
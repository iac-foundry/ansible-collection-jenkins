credentials:
  system:
    domainCredentials:
      - credentials:
          - basicSSHUserPrivateKey:
              scope: SYSTEM
              id: "{{ jenkins_agent_credentials_id }}"
              username: "{{ jenkins_agent_ssh_user }}"
              description: "SSH key for recyclable containerized Jenkins workers on infra orchestration nodes"
              privateKeySource:
                directEntry:
                  privateKey: |-
                    {{ jenkins_agent_private_key_text | replace('\n', '\n                    ') }}

jenkins:
  nodes:
{% for agent in jenkins_agent_nodes %}
    - permanent:
        name: "{{ agent.name }}"
    nodeDescription: "Managed by Ansible + JCasC as a recyclable containerized Jenkins worker"
        labelString: "{{ agent.labels }}"
        mode: "{{ agent.mode | default('EXCLUSIVE') }}"
        numExecutors: {{ agent.executors | default(1) }}
        remoteFS: "{{ agent.remote_fs }}"
        launcher:
          ssh:
            host: "{{ agent.host }}"
            port: {{ agent.port | default(22) }}
            credentialsId: "{{ jenkins_agent_credentials_id }}"
            launchTimeoutSeconds: {{ agent.launch_timeout | default(60) }}
            maxNumRetries: {{ agent.max_retries | default(10) }}
            retryWaitTime: {{ agent.retry_wait | default(15) }}
            sshHostKeyVerificationStrategy:
              knownHostsFileVerificationStrategy: {}
{% endfor %}
